 RowBox[{
  RowBox[{
   RowBox[{"GT1", "[", 
    RowBox[{"m_", ",", "n_", ",", "s_"}], "]"}], ":=", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", "p", ")"}], "n"], "t0"}]}], ";", 
  RowBox[{
   RowBox[{"GT2", "[", 
    RowBox[{"m_", ",", "n_", ",", "s_"}], "]"}], ":=", "t0"}], 

(* Beginning of Notebook Content *)
Notebook[{
Cell[TextData[{
 "In the following , one can reproduce the symmetry allowed mean field \
parameters for different Ansatze given in Table I of the preprint \
(arXiv:2409.17219v1). One need to insert the PSG parameters ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Eta]", ",", 
         SubscriptBox["\[Eta]", 
          SubscriptBox[
           StyleBox["C", "TI"], "6"]], ",", 
         SubscriptBox["\[Eta]", 
          RowBox[{
            SubscriptBox[
             StyleBox["C", "TI"], "6"], 
            StyleBox["R", "TI"]}]], ",", 
         SubscriptBox[
          StyleBox["g", "TI"], 
          SubscriptBox[
           StyleBox["C", "TI"], "6"]], ",", 
         SubscriptBox[
          StyleBox["g", "TI"], 
          StyleBox["R", "TI"]], ",", 
         SubscriptBox[
          StyleBox["g", "TI"], "\[Theta]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "$\\eta, \\eta_{C_6}, \\eta_{C_6R},g_{C_6},g_R,g_{\\theta}$", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3e33bc75-2896-4a2b-a7d1-1cda0118869f"],
 " from the PSG solutions given in the supplemental informations. ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["g", "TI"], 
          SubscriptBox[
           StyleBox["C", "TI"], "6"]], "\[LongEqual]", 
         SuperscriptBox["\[Tau]", "0"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "$g_{C_6}=\\tau^0$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "77556b5e-f07e-4b83-8f26-eab7a3f3be36"],
 " for all the cases. In the following script, we have shown for the Ansatz \
given by 8th row with ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"(", 
           RowBox[{"\[Eta]", ",", 
             SubscriptBox["\[Eta]", 
              SubscriptBox[
               StyleBox["C", "TI"], "6"]], ",", 
             SubscriptBox["\[Eta]", 
              RowBox[{
                SubscriptBox[
                 StyleBox["C", "TI"], "6"], 
                StyleBox["R", "TI"]}]], ",", 
             SubscriptBox["\[Eta]", 
              RowBox[{"\[CapitalTheta]", 
                StyleBox["R", "TI"]}]]}], ")"}], "\[LongEqual]", 
         RowBox[{"(", 
           RowBox[{"1", ",", "-1", ",", "-1", ",", "-1"}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "$(\\eta, \\eta_{C_6}, \\eta_{C_6R},\\eta_{\\Theta R})=(1,-1,-1,-1)$", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "624ea9cf-3f0d-4cbc-96ce-b6114647448d"],
 " which we concluded to give the fermionic spinon dynamics in Rydberg \
platform. We use the notation for ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{"\[Eta]", ",", 
           SubscriptBox["\[Eta]", 
            SubscriptBox[
             StyleBox["C", "TI"], "6"]], ",", 
           SubscriptBox["\[Eta]", 
            RowBox[{
              SubscriptBox[
               StyleBox["C", "TI"], "6"], 
              StyleBox["R", "TI"]}]], ",", 
           SubscriptBox["\[Eta]", 
            RowBox[{"\[CapitalTheta]", 
              StyleBox["R", "TI"]}]]}], ")"}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "$(\\eta, \\eta_{C_6}, \\eta_{C_6R},\\eta_{\\Theta R})$", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b51c8029-621f-4797-884e-b7d9de804b9c"],
 " as (e,eC6,eC6R,eTR).\n"
}], "Text",
 CellChangeTimes->{{3.9904382160677752`*^9, 3.990438353225772*^9}, {
   3.9904384790561447`*^9, 3.9904386148949437`*^9}, 3.9904386742403393`*^9, {
   3.990438811912533*^9, 3.990438927001646*^9}, {3.990439017280016*^9, 
   3.9904390546896963`*^9}},ExpressionUUID->"b33b62fa-53d2-456d-b8e2-\
6e83461fa228"],

Cell[CellGroupData[{

Cell[TextData[{
 "Allowed mean-field terms on the Triangular bond ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    SubscriptBox["u", "1"]}], TraditionalForm]],ExpressionUUID->
  "1a9977da-20fd-46e6-983d-f5cd16f98d13"],
 ")\nUsinglet=",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubsuperscriptBox[
        StyleBox["u", "TI"], "1", "0"], TraditionalForm], "errors" -> {}, 
     "input" -> "$u^0_1$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "010d3206-6c3c-4069-ad0f-e7b1ae602e52"],
 " Utriplet=",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubsuperscriptBox[
        StyleBox["u", "TI"], "1", 
        StyleBox["z", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "$u^z_1$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c03eabbb-c0c4-4368-9af6-56047be0e06f"]
}], "Title",
 CellChangeTimes->{{3.990434623200968*^9, 3.990434637637842*^9}, {
  3.9904353300175533`*^9, 3.9904353366101866`*^9}, {3.9904381300666313`*^9, 
  3.9904381332490797`*^9}, {3.9904391191678715`*^9, 
  3.9904391218457613`*^9}},ExpressionUUID->"880648fd-04f7-434e-9a16-\
a5d1cc48f265"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"$Assumptions", "=", 
    RowBox[{
     RowBox[{"Element", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"m", ",", "n"}], "}"}], ",", "Integers"}], "]"}], "&&", 
     RowBox[{"Element", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"h0", ",", "h1", ",", "h2", ",", "h3"}], "}"}], ",", 
       "Reals"}], "]"}]}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"t0", "=", 
   RowBox[{"(", GridBox[{
      {"1", "0"},
      {"0", "1"}
     }], ")"}]}], ";", " ", 
  RowBox[{"t3", "=", 
   RowBox[{"(", GridBox[{
      {"1", "0"},
      {"0", 
       RowBox[{"-", "1"}]}
     }], ")"}]}], ";", " ", 
  RowBox[{"t1", "=", 
   RowBox[{"(", GridBox[{
      {"0", "1"},
      {"1", "0"}
     }], ")"}]}], ";", " ", 
  RowBox[{"t2", "=", 
   RowBox[{"(", GridBox[{
      {"0", 
       RowBox[{"-", "I"}]},
      {"I", "0"}
     }], ")"}]}], ";", 
  RowBox[{"wc0", "=", "t0"}], ";", 
  RowBox[{"wc1", "=", " ", 
   RowBox[{"ec", " ", "t0"}]}], ";", 
  RowBox[{"ws0", "=", 
   RowBox[{"I", " ", "t3"}]}], ";", 
  RowBox[{"ws1", "=", 
   RowBox[{"es", " ", "I", " ", "t3"}]}], ";", 
  RowBox[{"es1", "=", 
   RowBox[{"+", "1"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"sig", "[", "s_", "]"}], ":=", 
   RowBox[{
    RowBox[{"3", " ", 
     RowBox[{"KroneckerDelta", "[", 
      RowBox[{"s", ",", "1"}], "]"}]}], "+", 
    RowBox[{"2", " ", 
     RowBox[{"KroneckerDelta", "[", 
      RowBox[{"s", ",", "2"}], "]"}]}], "+", 
    RowBox[{"1", " ", 
     RowBox[{"KroneckerDelta", "[", 
      RowBox[{"s", ",", "3"}], "]"}]}], "+", 
    RowBox[{"6", " ", 
     RowBox[{"KroneckerDelta", "[", 
      RowBox[{"s", ",", "4"}], "]"}]}], "+", 
    RowBox[{"5", " ", 
     RowBox[{"KroneckerDelta", "[", 
      RowBox[{"s", ",", "5"}], "]"}]}], "+", 
    RowBox[{"4", " ", 
     RowBox[{"KroneckerDelta", "[", 
      RowBox[{"s", ",", "6"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"T1", "[", 
    RowBox[{"m_", ",", "n_", ",", "s_"}], "]"}], ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"m", "+", "1"}], ",", "n", ",", "s"}], "}"}]}], ";", 
  RowBox[{
   RowBox[{"IT1", "[", 
    RowBox[{"m_", ",", "n_", ",", "s_"}], "]"}], ":=", 

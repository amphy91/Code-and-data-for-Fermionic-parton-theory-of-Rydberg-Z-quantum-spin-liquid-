    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "1", ",", "3"}], "}"}]}], "}"}]}], ";", 
  RowBox[{"uh", "=", 
   RowBox[{
    RowBox[{"I", " ", "h0", " ", "t0"}], "+", 
    RowBox[{"h1", " ", "t1"}], "+", 
    RowBox[{"h2", " ", "t2"}], "+", 
    RowBox[{"h3", " ", "t3"}]}]}], ";", 

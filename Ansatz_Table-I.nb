  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"C6", "[", 
    RowBox[{"m_", ",", "n_", ",", "s_"}], "]"}], ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"m", "-", "n"}], ",", "m", ",", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"s", "<=", "5"}], ",", 
       RowBox[{"s", "+", "1"}], ",", "1"}], "]"}]}], "}"}]}], ";", " ", 
  RowBox[{
   RowBox[{"IC6", "[", 
    RowBox[{"m_", ",", "n_", ",", "s_"}], "]"}], ":=", 
